# Copy this to .env and fill in your values
# Firebase — get these from your Firebase console project settings
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Vision API (for label detection on non-barcoded items)
EXPO_PUBLIC_GOOGLE_VISION_API_KEY=

# These MUST only be set in Firebase Cloud Functions environment, never here
# firebase functions:config:set openai.key="..." google_calendar.client_secret="..."
